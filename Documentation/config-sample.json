{
	"routes": {
		"/remote": {
			"disabled": true
		}
	},
	"webhooks": [
		{
			"url": "http://localhost:5678/webhook/YOUR-WORKFLOW-ID",
			"mode": "notify",
			"failurePolicy": { "maxRetries": 3 }
		},
		{
			"url": "http://localhost:5678/webhook/COMMAND-WORKFLOW-ID",
			"mode": "command",
			"auth": { "secret": "stored-in-keychain-see-docs" }
		},
		{
			"url": "https://webhook.site/2",
			"mode": "notify",
			"routes": [
				{
					"name": "/hello",
					"description": "a test route",
					"parameterSyntax": "/hello",
					"comparisons": {
						"startsWith": ["/hello"]
					}
				}
			]
		}
	],
	"webServer": {
		"port": 3001
	},
	"llm": {
		"provider": "openai",
		"apiKey": "sk-...",
		"model": "gpt-4o",
		"systemPrompt": "You are a helpful assistant.",
		"rateLimitSeconds": 10.0
	}
}